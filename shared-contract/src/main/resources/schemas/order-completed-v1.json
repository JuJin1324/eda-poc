{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://eda-poc/contracts/order-completed-v1.json",
    "title": "OrderCompletedEvent",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "eventId",
        "occurredAt",
        "orderId",
        "productId",
        "quantity",
        "customerId"
    ],
    "properties": {
        "eventId": {
            "type": "string",
            "minLength": 1
        },
        "occurredAt": {
            "type": "string",
            "format": "date-time"
        },
        "orderId": {
            "type": "string",
            "minLength": 1
        },
        "productId": {
            "type": "string",
            "minLength": 1
        },
        "quantity": {
            "type": "integer",
            "minimum": 1
        },
        "customerId": {
            "type": "string",
            "minLength": 1
        }
    }
}
